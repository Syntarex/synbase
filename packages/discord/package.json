{
    "name": "@synbase/discord",
    "version": "0.0.1",
    "private": true,
    "main": "lib/index.js",
    "scripts": {
        "prebuild": "yarn clean",
        "build": "tsc --build",
        "preserve": "yarn clean",
        "serve": "NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\" env-cmd -f ../../.env nodemon src/index.ts",
        "start": "node lib/main.js",
        "clean": "rimraf lib && rimraf tsconfig.tsbuildinfo"
    },
    "dependencies": {
        "@synbase/shared": "^0.0.1",
        "discord.js": "^13.8.0",
        "lodash": "^4.17.21",
        "openid-client": "^5.1.6"
    },
    "devDependencies": {
        "@types/lodash": "^4.14.182",
        "@types/node": "^17.0.42",
        "nodemon": "^2.0.16",
        "ts-node": "^10.8.1"
    }
}
