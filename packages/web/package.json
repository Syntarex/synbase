{
    "name": "@synbase/web",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "clean": "rimraf .next",
        "prebuild": "yarn clean",
        "preserve": "yarn clean",
        "dev:server": "NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\" env-cmd -f ../../.env next dev -p 8079",
        "dev:proxy": "local-ssl-proxy --key ../../ssl-key.pem --cert ../../ssl-cert.pem --source 8080 --target 8079",
        "serve": "npm-run-all --parallel dev:**",
        "build": "next build",
        "start": "next start -p 8080"
    },
    "dependencies": {
        "@emotion/cache": "^11.7.1",
        "@emotion/css": "^11.7.1",
        "@emotion/react": "^11.8.2",
        "@emotion/server": "^11.4.0",
        "@emotion/styled": "^11.8.1",
        "@iconify/react": "^3.1.4",
        "@mui/icons-material": "^5.5.1",
        "@mui/material": "^5.5.1",
        "@mui/styles": "^5.6.0",
        "@synbase/shared": "^0.0.1",
        "dayjs": "^1.11.0",
        "draft-js": "^0.11.7",
        "formik": "^2.2.9",
        "lodash": "^4.17.21",
        "next": "^12.1.0",
        "next-auth": "^4.2.1",
        "prism-react-renderer": "^1.3.1",
        "react": "^17.0.2",
        "react-dom": "^17.0.2",
        "react-dropzone": "^12.0.4",
        "react-query": "^3.34.16",
        "recoil": "^0.6.1",
        "use-error-boundary": "^2.0.6",
        "uuid": "^8.3.2",
        "yup": "^0.32.11"
    },
    "devDependencies": {
        "@types/cookie": "^0.4.1",
        "@types/draft-js": "^0.11.9",
        "@types/lodash": "^4.14.180",
        "@types/multer": "^1.4.7",
        "@types/node": "^17.0.21",
        "@types/react": "^17.0.40",
        "@types/uuid": "^8.3.4",
        "local-ssl-proxy": "^1.3.0",
        "npm-run-all": "^4.1.5"
    }
}
