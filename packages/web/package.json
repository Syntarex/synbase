{
    "name": "@synbase/web",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "clean": "rimraf .next",
        "prebuild": "yarn clean",
        "preserve": "yarn clean",
        "dev:server": "NODE_EXTRA_CA_CERTS=\"$(mkcert -CAROOT)/rootCA.pem\" env-cmd -f ../../.env next dev -p 8079",
        "dev:proxy": "local-ssl-proxy --key ../../ssl-key.pem --cert ../../ssl-cert.pem --source 8080 --target 8079",
        "serve": "npm-run-all --parallel dev:**",
        "build": "next build",
        "start": "next start -p 8080"
    },
    "dependencies": {
        "@emotion/cache": "^11.9.3",
        "@emotion/css": "^11.9.0",
        "@emotion/react": "^11.9.3",
        "@emotion/server": "^11.4.0",
        "@emotion/styled": "^11.9.3",
        "@iconify/react": "^3.2.1",
        "@mui/icons-material": "^5.8.3",
        "@mui/material": "^5.8.3",
        "@mui/styles": "^5.8.3",
        "@synbase/shared": "^0.0.1",
        "dayjs": "^1.11.3",
        "formik": "^2.2.9",
        "lodash": "^4.17.21",
        "markdown-to-jsx": "^7.1.7",
        "mui-markdown": "^0.5.3",
        "next": "^12.1.6",
        "next-auth": "^4.5.0",
        "prism-react-renderer": "^1.3.3",
        "react": "^18.1.0",
        "react-dom": "^18.1.0",
        "react-dropzone": "^14.2.1",
        "react-query": "^3.39.1",
        "recoil": "^0.7.3",
        "use-error-boundary": "^2.0.6",
        "uuid": "^8.3.2",
        "yup": "^0.32.11"
    },
    "devDependencies": {
        "@types/cookie": "^0.5.1",
        "@types/lodash": "^4.14.182",
        "@types/multer": "^1.4.7",
        "@types/node": "^17.0.42",
        "@types/react": "^18.0.12",
        "@types/uuid": "^8.3.4",
        "local-ssl-proxy": "^1.3.0",
        "npm-run-all": "^4.1.5"
    }
}
