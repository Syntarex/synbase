{
    "name": "@synbase/web",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "clean": "rimraf .next",
        "prebuild": "yarn clean",
        "dev:server": "env-cmd -f ../../.env next dev -p 8079",
        "dev:proxy": "local-ssl-proxy --key ../../ssl-key.pem --cert ../../ssl-cert.pem --source 8080 --target 8079",
        "serve": "npm-run-all --parallel dev:**",
        "build": "next build",
        "start": "next start -p 8080"
    },
    "dependencies": {
        "next": "^12.1.0",
        "react": "^17.0.2",
        "react-dom": "^17.0.2"
    },
    "devDependencies": {
        "@types/node": "^17.0.19",
        "@types/react": "^17.0.39",
        "local-ssl-proxy": "^1.3.0",
        "npm-run-all": "^4.1.5"
    }
}
