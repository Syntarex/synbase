{
    "compilerOptions": {
        "module": "commonjs",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "declaration": true,
        "removeComments": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "target": "es2017",
        "sourceMap": true,
        "incremental": true,
        "strict": true,
        "importHelpers": true,
        "lib": ["es2017", "dom"],
        "jsx": "react"
    }
}
